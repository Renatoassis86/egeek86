# Copie este arquivo para .env.local e preencha com seus valores
# Pegue tudo em: Supabase Dashboard → seu projeto

# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ============================================================
# DATABASE (Postgres do Supabase, para Drizzle)
# ============================================================
# Transaction pooler (porta 6543) — runtime
DATABASE_URL=
# Direct/Session connection (porta 5432) — migrations
DIRECT_URL=

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# GEEK DEALS — Coletor automático de preços
# ============================================================
# Segredo aleatório que protege /api/cron/collect-prices — gere com:
# openssl rand -hex 32 (ou qualquer gerador de string aleatória)
CRON_SECRET=

# Cadastro gratuito em developers.mercadolivre.com.br → Minhas aplicações
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
MERCADO_LIVRE_ACCESS_TOKEN=
MERCADO_LIVRE_REFRESH_TOKEN=

# Amazon PA-API 5.0 (Product Advertising API) — exige conta de Associados
# aprovada com vendas qualificadas nos últimos 30 dias. Estrutura pronta,
# aguardando credenciais (ver src/server/collector/sources/amazon.ts).
AMAZON_PA_API_ACCESS_KEY=
AMAZON_PA_API_SECRET_KEY=
AMAZON_PA_API_PARTNER_TAG=

# Shopee Affiliate API (affiliateshopee.com.br) — App ID/Secret aprovados
# pela Shopee. Estrutura pronta, aguardando credenciais (ver
# src/server/collector/sources/shopee.ts).
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_APP_SECRET=

# AliExpress Affiliate API (portals.aliexpress.com/affiportals) — App
# Key/Secret do Portal de Afiliados. Estrutura pronta, aguardando
# credenciais (ver src/server/collector/sources/aliexpress.ts).
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# ============================================================
# GEEK DEALS — Notificações (alerta diário de queda de preço)
# ============================================================
# Bot criado via @BotFather no Telegram — ver docs/pg-cron-setup.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Segredo aleatório pro webhook validar que a chamada é do Telegram mesmo
# (header X-Telegram-Bot-Api-Secret-Token) — gere com: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Conta em resend.com — precisa verificar domínio de envio antes de mandar
# pra e-mails arbitrários (sandbox só manda pro próprio e-mail da conta).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
